# Public Supabase client config (safe to expose in the browser; protect data with RLS).
# Copy to .env.local for local dev. In Cloud Run, set these as build/runtime env vars
# or inject from Secret Manager (see SECURITY_NOTES.md).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
